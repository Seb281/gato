            "in": "query",
            "name": "type",
            "required": false
          },
          {
            "schema": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100
            },
            "in": "query",
            "name": "count",
            "required": false
          }
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "questions": {
                      "type": "array",
                      "items": {
                        "anyOf": [
                          {
                            "type": "object",
                            "properties": {
                              "conceptId": {
                                "type": "integer",
                                "minimum": -9007199254740991,
                                "maximum": 9007199254740991
                              },
                              "concept": {
                                "type": "string"
                              },
                              "translation": {
                                "type": "string"
                              },
                              "sourceLanguage": {
                                "type": "string"
                              },
                              "targetLanguage": {
                                "type": "string"
                              },
                              "phoneticApproximation": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "commonUsage": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "schedule": {
                                "$ref": "#/components/schemas/ReviewSchedule"
                              }
                            },
                            "required": [
                              "conceptId",
                              "concept",
                              "translation",
                              "sourceLanguage",
                              "targetLanguage",
                              "schedule"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "conceptId": {
                                "type": "integer",
                                "minimum": -9007199254740991,
                                "maximum": 9007199254740991
                              },
                              "concept": {
                                "type": "string"
                              },
                              "sourceLanguage": {
                                "type": "string"
                              },
                              "targetLanguage": {
                                "type": "string"
                              },
                              "phoneticApproximation": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "correctAnswer": {
                                "type": "string"
                              },
                              "options": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "schedule": {
                                "$ref": "#/components/schemas/ReviewSchedule"
                              }
                            },
                            "required": [
                              "conceptId",
                              "concept",
                              "sourceLanguage",
                              "targetLanguage",
                              "correctAnswer",
                              "options",
                              "schedule"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "conceptId": {
                                "type": "integer",
                                "minimum": -9007199254740991,
                                "maximum": 9007199254740991
                              },
                              "concept": {
                                "type": "string"
                              },
                              "translation": {
                                "type": "string"
                              },
                              "contextBefore": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "contextAfter": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "sourceLanguage": {
                                "type": "string"
                              },
                              "targetLanguage": {
                                "type": "string"
                              },
                              "phoneticApproximation": {
                                "anyOf": [
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "schedule": {
                                "$ref": "#/components/schemas/ReviewSchedule"
                              }
                            },
                            "required": [
                              "conceptId",
                              "concept",
                              "translation",
                              "sourceLanguage",
                              "targetLanguage",
                              "schedule"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      }
                    }
                  },
                  "required": [
                    "questions"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
