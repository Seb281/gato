# Copy this file to `apps/web/.env.test` and fill in real values.
# The live file is gitignored — never commit credentials.
# In CI these are injected from GitHub Actions secrets instead.

# Supabase project credentials (publishable key is client-safe, URL is public).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# API origin the dashboard proxy forwards to. Any reachable URL works for
# auth-only smoke tests; point at your staging API for richer flows.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dedicated Supabase test user (create one in the dashboard if none exists).
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
